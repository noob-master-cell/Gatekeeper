# ──────────────────────────────────────────────────────────────
# Gatekeeper — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env with real secrets to version control.

# ── Google OAuth 2.0 ─────────────────────────────────────────
GK_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GK_GOOGLE_CLIENT_SECRET=your-google-client-secret
GK_GOOGLE_REDIRECT_URI=https://your-domain.com/oauth/callback

# ── App Mode ─────────────────────────────────────────────────
GK_DEV_MODE=false
GK_DEV_LOGIN_ENABLED=false

# ── JWT ──────────────────────────────────────────────────────
GK_JWT_EXPIRY_MINUTES=60
GK_KEYS_DIR=/tmp/gatekeeper_keys

# ── Proxy ────────────────────────────────────────────────────
GK_BACKEND_URL=http://backend:8001
GK_CONTROL_PLANE_URL=http://control-plane:8002
GK_LOG_LEVEL=INFO

# ── Redis ────────────────────────────────────────────────────
GK_REDIS_URL=redis://redis:6379/0

# ── mTLS ─────────────────────────────────────────────────────
GK_MTLS_ENABLED=false
GK_MTLS_CERT_DIR=/certs

# ── Control Plane ────────────────────────────────────────────
GK_CP_DATABASE_URL=postgresql+asyncpg://gatekeeper:CHANGE_ME@postgres:5432/gatekeeper
GK_CP_REDIS_URL=redis://redis:6379/0
GK_CP_LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=gatekeeper
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=gatekeeper
