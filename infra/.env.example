# ─── Proxy ────────────────────────────────
GK_BACKEND_URL=http://backend:8001
GK_PROXY_HOST=0.0.0.0
GK_PROXY_PORT=8000
GK_BACKEND_CONNECT_TIMEOUT=5.0
GK_BACKEND_READ_TIMEOUT=30.0
GK_LOG_LEVEL=INFO
GK_DEV_MODE=true

# ─── PostgreSQL ───────────────────────────
POSTGRES_USER=gatekeeper
POSTGRES_PASSWORD=gatekeeper_dev
POSTGRES_DB=gatekeeper
DATABASE_URL=postgresql+asyncpg://gatekeeper:gatekeeper_dev@postgres:5432/gatekeeper

# ─── Redis ────────────────────────────────
REDIS_URL=redis://redis:6379/0
